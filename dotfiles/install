#!/usr/bin/env bash
set -euo pipefail

SOURCE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CHEZMOI_SOURCE="${HOME}/.local/share/chezmoi"

MISE_CONFIG="${SOURCE_DIR}/mise.toml"
if [[ ! -f "${MISE_CONFIG}" ]]; then
  MISE_CONFIG="${SOURCE_DIR}/../mise.toml"
fi

ensure_path() {
  export PATH="${HOME}/.local/share/mise/shims:${HOME}/.local/bin:${PATH}"
}

is_debian() {
  [[ -f /etc/debian_version ]]
}

is_wsl() {
  [[ -f /proc/sys/kernel/osrelease ]] &&
    grep -qiE 'microsoft|wsl' /proc/sys/kernel/osrelease
}

ensure_dependencies() {
  local -a deps=(curl git)
  local -a missing=()

  for dep in "${deps[@]}"; do
    command -v "${dep}" >/dev/null 2>&1 || missing+=("${dep}")
  done

  if ((${#missing[@]} == 0)); then
    return 0
  fi

  echo "Missing required tools: ${missing[*]}" >&2
  if is_debian; then
    echo "Install with: sudo apt-get update && sudo apt-get install -y ${missing[*]}" >&2
  fi
  exit 1
}

install_mise() {
  if command -v mise >/dev/null 2>&1; then
    return 0
  fi

  echo "Installing mise (https://mise.jdx.dev)" >&2
  curl -fsSL https://mise.run | sh
  ensure_path
}

install_tools() {
  echo "Installing tools from $(basename "${MISE_CONFIG}") (chezmoi, …)" >&2
  mise trust -y "${MISE_CONFIG}"
  mise install -C "$(dirname "${MISE_CONFIG}")"
  ensure_path
}

apply_dotfiles() {
  if ! command -v chezmoi >/dev/null 2>&1; then
    echo "chezmoi not found after mise install; check ${MISE_CONFIG}" >&2
    exit 1
  fi

  mkdir -p "${HOME}/.local/share"
  ln -sfn "${SOURCE_DIR}" "${CHEZMOI_SOURCE}"
  chezmoi apply
}

zsh_in_etc_shells() {
  local zsh_path="$1"
  grep -Fxq "${zsh_path}" /etc/shells 2>/dev/null
}

ensure_zsh() {
  local zsh_path login_shell

  zsh_path="$(command -v zsh || true)"
  login_shell="$(getent passwd "${USER}" | cut -d: -f7)"

  if [[ -z "${zsh_path}" ]]; then
    echo "" >&2
    echo "WARNING: zsh is not installed. These dotfiles configure zsh (~/.config/zsh)." >&2
    if is_debian; then
      echo "Install with: sudo apt-get install -y zsh" >&2
    else
      echo "Install zsh with your system package manager, then re-run this script." >&2
    fi
    echo "" >&2
    return 0
  fi

  if [[ "${login_shell}" == "${zsh_path}" ]]; then
    return 0
  fi

  echo "" >&2
  echo "WARNING: Login shell is ${login_shell}, not zsh (${zsh_path})." >&2
  echo "New login sessions will not load ~/.config/zsh until you switch shells." >&2
  echo "" >&2

  if ! zsh_in_etc_shells "${zsh_path}"; then
    echo "zsh is not listed in /etc/shells. Add it first:" >&2
    echo "  echo '${zsh_path}' | sudo tee -a /etc/shells" >&2
    echo "" >&2
  fi

  echo "To set zsh as your login shell:" >&2
  echo "  chsh -s ${zsh_path} ${USER}" >&2
  if is_wsl; then
    echo "" >&2
    echo "WSL detected (kernel: $(cat /proc/sys/kernel/osrelease))." >&2
    echo "If chsh does not stick, try: sudo usermod -s ${zsh_path} ${USER}" >&2
  fi
  echo "" >&2

  if [[ -t 0 ]]; then
    read -r -p "Run chsh now? [y/N] " reply
    if [[ "${reply}" =~ ^[Yy]$ ]]; then
      chsh -s "${zsh_path}" "${USER}"
      echo "Login shell updated. Open a new session for it to take effect." >&2
    fi
  fi
}

main() {
  ensure_path
  ensure_dependencies
  install_mise
  install_tools
  apply_dotfiles
  ensure_zsh
}

main "$@"
