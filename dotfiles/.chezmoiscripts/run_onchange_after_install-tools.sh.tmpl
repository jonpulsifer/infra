#!/usr/bin/env bash
set -euo pipefail
# Brewfile checksum: {{ include "Brewfile" | sha256sum }}
export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

if [[ "$(uname -s)" == "Darwin" ]]; then
  if command -v brew >/dev/null 2>&1; then
    brew bundle install --no-upgrade --file "{{ .chezmoi.sourceDir }}/Brewfile"
  else
    echo "chezmoi: brew not found; skipping Homebrew bundle install" >&2
  fi
fi

if ! command -v mise >/dev/null 2>&1; then
  echo "chezmoi: mise not found; run chezmoi apply again after run_once_install-mise" >&2
  exit 0
fi
export MISE_NODE_COMPILE=false
mise trust -y "${HOME}/.config/mise/config.toml" 2>/dev/null || true
mise install -C "${HOME}"
