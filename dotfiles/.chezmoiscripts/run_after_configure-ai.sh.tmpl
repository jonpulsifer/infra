#!/usr/bin/env bash
set -euo pipefail
command -v jq >/dev/null 2>&1 || exit 0

# Merge MCP servers into ~/.claude.json (preserves runtime state like numStartups)
MCP_SOURCE="{{ .chezmoi.homeDir }}/.claude/mcp-servers.json"
CLAUDE_JSON="{{ .chezmoi.homeDir }}/.claude.json"

if [[ -f "$MCP_SOURCE" ]]; then
  MCP="$(cat "$MCP_SOURCE")"
  if [[ -f "$CLAUDE_JSON" ]]; then
    jq --argjson mcp "$MCP" '.mcpServers = $mcp' "$CLAUDE_JSON" >"${CLAUDE_JSON}.tmp" && mv "${CLAUDE_JSON}.tmp" "$CLAUDE_JSON"
  else
    printf '%s\n' "{\"mcpServers\": $MCP}" >"$CLAUDE_JSON"
  fi
fi

# Merge chezmoi-managed settings into ~/.claude/settings.json
SETTINGS_MERGE="{{ .chezmoi.homeDir }}/.claude/settings.chezmoi.json"
SETTINGS="{{ .chezmoi.homeDir }}/.claude/settings.json"

if [[ -f "$SETTINGS_MERGE" ]]; then
  if [[ -f "$SETTINGS" ]]; then
    jq -s '.[0] * .[1]' "$SETTINGS" "$SETTINGS_MERGE" >"${SETTINGS}.tmp" && mv "${SETTINGS}.tmp" "$SETTINGS"
  else
    mkdir -p "$(dirname "$SETTINGS")"
    cp "$SETTINGS_MERGE" "$SETTINGS"
  fi
fi
