[settings]
experimental = true
minimum_release_age_excludes = ["claude-code", "codex", "pi", "opencode"]


[tools]
bat = "latest"
delta = "latest"
eza = "latest"
fd = "latest"
fzf = "latest"
gh = "latest"
jq = "latest"
ripgrep = "latest"
sd = "latest"
1password-cli = "latest"

# cloud stuff
kubectl = "latest"
helm = "latest"
k9s = "latest"
kubecolor = "latest"
kubectx = "latest"
kubens = "latest"
krew = "latest"

{{- if eq .chezmoi.os "linux" }}
btop = "latest"
neovim = "latest"
node = "latest" # runtime for npm-based LSP servers (yamlls, bashls, jsonls) installed by mason
{{- if contains "microsoft" .chezmoi.kernel.osrelease }}
gcloud = "latest"
codex = "latest"
claude-code = "latest"
opencode = "latest"
pi = "latest"
{{- end }}
{{- end }}
