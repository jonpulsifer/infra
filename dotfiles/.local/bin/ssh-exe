#!/usr/bin/env bash
# WSL: Windows OpenSSH (1Password agent, shared keys with git signing).
# Elsewhere: passthrough to system ssh.
# WSL sets WSL_DISTRO_NAME for every session it launches.
if [[ -n ${WSL_DISTRO_NAME-} ]] && command -v ssh.exe &>/dev/null; then
  exec ssh.exe "$@"
fi

exec /usr/bin/ssh "$@"
