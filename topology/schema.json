{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jonpulsifer/infra/topology/schema.json",
  "title": "Homelab network topology",
  "description": "Single source of truth for homelab network facts (IPs, CIDRs, ASNs) consumed by Nix, Terraform, and Flux. See topology/README.md.",
  "type": "object",
  "additionalProperties": false,
  "required": ["constants", "clusters"],
  "properties": {
    "$schema": { "type": "string" },
    "constants": {
      "type": "object",
      "additionalProperties": false,
      "required": ["apiServerPort", "ciliumNativeRoutingCidr", "bgp"],
      "properties": {
        "apiServerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "ciliumNativeRoutingCidr": { "$ref": "#/$defs/cidr" },
        "bgp": {
          "type": "object",
          "additionalProperties": false,
          "required": ["gatewayAsn", "ciliumAsn"],
          "properties": {
            "gatewayAsn": { "type": "integer" },
            "ciliumAsn": { "type": "integer" }
          }
        }
      }
    },
    "clusters": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/cluster" }
    }
  },
  "$defs": {
    "ipv4": {
      "type": "string",
      "pattern": "^(\\d{1,3}\\.){3}\\d{1,3}$"
    },
    "cidr": {
      "type": "string",
      "pattern": "^(\\d{1,3}\\.){3}\\d{1,3}/\\d{1,2}$"
    },
    "cluster": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clusterName",
        "apiServerIP",
        "apiServerHostname",
        "routerIp",
        "nodeCidr",
        "podCidr",
        "serviceCidr",
        "clusterDns",
        "lbPool"
      ],
      "properties": {
        "clusterName": { "type": "string" },
        "apiServerIP": { "$ref": "#/$defs/ipv4" },
        "apiServerHostname": { "type": "string", "format": "hostname" },
        "routerIp": { "$ref": "#/$defs/ipv4" },
        "nodeCidr": { "$ref": "#/$defs/cidr" },
        "podCidr": { "$ref": "#/$defs/cidr" },
        "serviceCidr": { "$ref": "#/$defs/cidr" },
        "clusterDns": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ipv4" }
        },
        "lbPool": { "$ref": "#/$defs/cidr" },
        "bgpNeighbors": {
          "type": "array",
          "items": { "$ref": "#/$defs/ipv4" }
        }
      }
    }
  }
}
