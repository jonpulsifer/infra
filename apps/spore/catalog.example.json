{
  "serverOrigin": "http://127.0.0.1:3000/spore",
  "allowUnknownHosts": true,
  "defaultProfile": "local",
  "profiles": {
    "local": {
      "name": "Local development",
      "description": "Safe example profile",
      "content": "#!ipxe\necho Spore development request for {{hostname}} ({{mac}})\nexit\n"
    }
  },
  "scripts": {
    "example.ipxe": {
      "description": "Example chainable script",
      "content": "#!ipxe\necho Served by {{base_url}} for {{mac}}\nexit\n"
    }
  },
  "hosts": {
    "02:00:00:00:00:01": {
      "hostname": "example-host",
      "profile": "local"
    }
  }
}
