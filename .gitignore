# ─── Nix / NixOS ──────────────────────────────────────────────────────────────
result
result*
*.nixexpr
*.nixpkgs
*.iso
*.img
*.backup
*.wsl
*.zstd

# ─── Terraform ───────────────────────────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
*.tfvars

# ─── Build Artifacts ─────────────────────────────────────────────────────────
build/
dist/
out/
*.tgz

# ─── Logseq (docs/ wiki graph) ───────────────────────────────────────────────
# Track pages/journals + logseq/{config.edn,custom.css}; ignore app state.
docs/logseq/bak/
docs/logseq/.recycle/
docs/logseq/graphs-txid.edn
docs/logseq/broken-config.edn
docs/logseq/metadata.edn
docs/.trash/

# ─── Agent / AI Tooling ──────────────────────────────────────────────────────
# Ignore local/personal Claude config, but track the shared session-start hook
# + settings so Claude Code on the web bootstraps the toolchain.
.claude/*
!.claude/settings.json
!.claude/hooks/
.claude/settings.local.json
.agents/

# ─── Node / Bun ──────────────────────────────────────────────────────────────
# Root is a Bun workspace (apps/*, packages/*); bun.lock is tracked.
node_modules/

# ─── IDE / Editor ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs & Reports ───────────────────────────────────────────────────────────
*.log
logs/
coverage/
*.lcov

# ─── PKI ceremony artifacts ──────────────────────────────────────────────────
# Generated by pki/offline-root-ceremony.sh — never commit CA keys/certs.
pki/export/
